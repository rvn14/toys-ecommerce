# Backend
APP_ENV=development
PORT=8080
DATABASE_URL="host=your-supabase-pooler-host user=your-db-user password=your-db-password dbname=postgres port=5432 sslmode=require TimeZone=Asia/Colombo"
JWT_SECRET=your_jwt_secret_here
ACCESS_TOKEN_EXPIRES_MINUTES=60
FRONTEND_ORIGIN=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1

# Used by Next.js Server Components inside the Docker network.
# docker-compose.yml sets this automatically to http://backend:8080/api/v1.
INTERNAL_API_BASE_URL=http://backend:8080/api/v1
